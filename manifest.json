{
  "manifest_version": 3,
  "name": "Fidelity Account Order",
  "description": "Manually reorder accounts in the Fidelity portfolio account selector.",
  "version": "1.0.0",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://fidelity.com/*", "https://*.fidelity.com/*"],
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "Fidelity Account Order",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://fidelity.com/*", "https://*.fidelity.com/*"],
      "js": ["src/utils.js", "src/fidelity-dom.js", "src/content.js"],
      "run_at": "document_start"
    }
  ]
}
