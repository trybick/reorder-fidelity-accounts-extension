{
  "manifest_version": 3,
  "name": "Reorder Fidelity Accounts",
  "description": "Control the order of accounts in the Fidelity portfolio page.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "host_permissions": ["*://*.fidelity.com/*"],
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "Reorder Fidelity Accounts",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.fidelity.com/*"],
      "js": ["src/utils.js", "src/dom-selectors.js", "src/content.js"],
      "run_at": "document_start"
    }
  ]
}
